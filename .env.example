# Скопіюйте цей файл у .env і заповніть реальними значеннями.
# .env вже в .gitignore — ніколи не комітиться і не вставляється в чат.

# HostBill API (домен: https://cp.astra.in.ua/)
HOSTBILL_API_URL=https://cp.astra.in.ua/admin/api.php

# Скоупований ключ "portal-readonly" — тільки read-only методи
# (getProducts, getProductDetails, getProductTypes, getCurrencies,
# getClients, verifyClientLogin, getPaymentModules). API ID і API Key —
# завжди пара, обидва обов'язкові.
HOSTBILL_PORTAL_READONLY_API_ID=
HOSTBILL_PORTAL_READONLY_API_KEY=

# Секрет для перевірки підпису вхідних webhook від HostBill
# (HB-Hook / HB-Timestamp) — не є API-ключем, окремий секрет.
HOSTBILL_WEBHOOK_SECRET=

# Коли дійдемо до фази "Чекаут" — додасться ще одна пара під дії клієнта:
# HOSTBILL_PORTAL_ACTIONS_API_ID=
# HOSTBILL_PORTAL_ACTIONS_API_KEY=

# PostgreSQL (локально — контейнер із docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/astracloud

# Payload CMS
PAYLOAD_SECRET=
