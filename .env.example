# Скопіюйте цей файл у .env і заповніть реальними значеннями.
# .env вже в .gitignore — ніколи не комітиться і не вставляється в чат.

# HostBill API (домен: https://cp.astra.in.ua/)
HOSTBILL_API_URL=https://cp.astra.in.ua/admin/api.php

# Публічний домен клієнтського порталу HostBill (НЕ /admin/api.php вище —
# це адреса, куди переходить браузер клієнта при натисканні "Замовити").
# Використовується для посилання виду cart.php?a=add&pid=<id>.
# На проді — https://cp.astra.in.ua/ (з завершальним "/").
HOSTBILL_STOREFRONT_URL=

# Скоупований ключ "portal-readonly" — тільки read-only методи
# (getProducts, getProductDetails, getProductTypes, getCurrencies,
# getClients, verifyClientLogin, getPaymentModules). API ID і API Key —
# завжди пара, обидва обов'язкові.
HOSTBILL_PORTAL_READONLY_API_ID=
HOSTBILL_PORTAL_READONLY_API_KEY=

# Секрет для перевірки підпису вхідних webhook від HostBill
# (HB-Hook / HB-Timestamp) — не є API-ключем, окремий секрет.
HOSTBILL_WEBHOOK_SECRET=

# Коли дійдемо до фази "Чекаут" — додасться ще одна пара під дії клієнта:
# HOSTBILL_PORTAL_ACTIONS_API_ID=
# HOSTBILL_PORTAL_ACTIONS_API_KEY=

# PostgreSQL (локально — контейнер із docker-compose; порт 5433, не 5432,
# щоб не конфліктувати з Postgres іншого проєкту на цій машині)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/astracloud

# Payload CMS
PAYLOAD_SECRET=

# Обліковий запис адміністратора Payload для агента (заповніть самі)
AGENT_ADMIN_EMAIL=
AGENT_ADMIN_PASSWORD=

# Довільний рядок — захищає POST /api/revalidate-vps-pricing (ручне
# оновлення кешу тарифів VPS одразу після зміни ціни в HostBill,
# не чекаючи 10-хвилинний TTL). Див. README "Live pricing (HostBill)".
REVALIDATE_SECRET=

# Надсилання заявок з форми "Отримати консультацію" через Gmail SMTP.
# GMAIL_SMTP_USER — Gmail-адреса, від імені якої надсилаються листи.
# GMAIL_SMTP_APP_PASSWORD — 16-символьний пароль застосунку (НЕ звичайний
# пароль від акаунта): Google Account → Security → 2-Step Verification →
# App passwords. Потребує увімкненої двофакторної автентифікації на акаунті.
# CONSULTATION_RECIPIENT_EMAIL — куди приходять заявки (можна лишити тим
# самим, що й GMAIL_SMTP_USER).
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
CONSULTATION_RECIPIENT_EMAIL=
